# Solana network: mainnet, devnet, or testnet
SOLANA_NETWORK=devnet

# RPC endpoints (get from Helius, QuickNode, etc.)
SOLANA_RPC_DEVNET_URL=https://api.devnet.solana.com
SOLANA_WS_DEVNET_URL=wss://api.devnet.solana.com

# For mainnet (uncomment when ready)
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Jupiter API key (used by solrengine-tokens for token metadata & prices)
# Get one at https://portal.jup.ag
# JUPITER_API_KEY=

# Domain for SIWS message verification and Rails DNS rebinding protection.
# MUST be set to your real domain in production (e.g. app.example.com) —
# SIWS signatures are tied to this value and login will fail on mismatch.
APP_DOMAIN=localhost

# Server keypair for signing transactions (base58 or JSON array)
# Only needed if the dApp requires server-side signing
# SOLANA_KEYPAIR=

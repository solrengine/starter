<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "SolRengine Starter" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="application-name" content="SolRengine Starter">
    <meta name="description" content="<%= content_for(:description) || "Your first Solana dApp built in Rails. Wallet auth, token display, SOL transfers, and 20+ UI components." %>">

    <meta property="og:title" content="<%= content_for(:title) || "SolRengine Starter" %>">
    <meta property="og:description" content="<%= content_for(:description) || "Your first Solana dApp built in Rails. Wallet auth, token display, SOL transfers, and 20+ UI components." %>">
    <meta property="og:image" content="<%= request.base_url %>/og.png">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="SolRengine Starter">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:title) || "SolRengine Starter" %>">
    <meta name="twitter:description" content="<%= content_for(:description) || "Your first Solana dApp built in Rails. Wallet auth, token display, SOL transfers, and 20+ UI components." %>">
    <meta name="twitter:image" content="<%= request.base_url %>/og.png">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Theme toggle disabled — dark mode only for now.
        To re-enable: uncomment the javascript_tag block below and the
        ThemeToggleComponent renders in dashboard/show and pages/home. %>
    <%#= javascript_tag nonce: true do %>
    <%#   const theme = localStorage.getItem('theme'); %>
    <%#   if (theme === 'light') document.documentElement.classList.remove('dark'); %>
    <%# end %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen">
    <% if logged_in? %>
      <nav class="border-b border-gray-200 dark:border-gray-800 bg-white/80 dark:bg-gray-900/50 backdrop-blur sticky top-0 z-10"
           data-controller="sui-collapse">
        <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
          <div class="flex items-center gap-6">
            <a href="<%= dashboard_path %>" class="flex items-center gap-2">
              <svg class="w-7 h-7 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
              <span class="text-xl font-bold text-gray-900 dark:text-white">
                <span class="hidden sm:inline">SolRengine </span>Starter
              </span>
            </a>
            <div class="hidden md:flex items-center gap-4">
              <%= nav_link_to "Dashboard", dashboard_path %>
              <%= nav_link_to "Tokens", tokens_path %>
              <%= nav_link_to "Send", send_path %>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <%= render Solrengine::Ui::NetworkBadgeComponent.new(network: current_network) %>
            <span class="hidden sm:inline">
              <%= render Solrengine::Ui::WalletButtonComponent.new(
                current_user: current_user,
                logout_path: logout_path
              ) %>
            </span>
            <button data-action="click->sui-collapse#toggle" class="md:hidden p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
        <div data-sui-collapse-target="content" class="hidden md:hidden border-t border-gray-200 dark:border-gray-800">
          <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-3">
            <%= nav_link_to "Dashboard", dashboard_path %>
            <%= nav_link_to "Tokens", tokens_path %>
            <%= nav_link_to "Send", send_path %>
            <div class="sm:hidden pt-2 border-t border-gray-200 dark:border-gray-800">
              <%= render Solrengine::Ui::WalletButtonComponent.new(
                current_user: current_user,
                logout_path: logout_path
              ) %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <% if notice || alert %>
      <div class="max-w-5xl mx-auto px-6 pt-4">
        <% if notice %>
          <%= render Solrengine::Ui::NotificationComponent.new(message: notice, type: :success) %>
        <% end %>
        <% if alert %>
          <%= render Solrengine::Ui::NotificationComponent.new(message: alert, type: :error) %>
        <% end %>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <%= render Solrengine::Ui::FooterComponent.new do |f| %>
      <% f.with_link do %>
        <a href="https://solrengine.org" target="_blank" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">SolRengine</a>
      <% end %>
      <% f.with_link do %>
        <a href="https://github.com/solrengine/starter" target="_blank" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">GitHub</a>
      <% end %>
      <% f.with_powered_by do %>
        Built with <a href="https://solrengine.org" class="text-purple-400 hover:text-purple-300">SolRengine</a> on Solana
      <% end %>
    <% end %>
  </body>
</html>
